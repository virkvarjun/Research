      "observation.images.wrist": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [18]
      },
      "action": {
        "type": "ACTION",
        "shape": [3]
